{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets":
  [
    { "name": "base",  "hidden": true, "generator": "Ninja", "binaryDir": "${sourceDir}/build/${presetName}" },
    { "name": "gcc",   "hidden": true, "inherits": "base",   "environment": { "CC": "gcc",   "CXX": "g++"     } },
    { "name": "clang", "hidden": true, "inherits": "base",   "environment": { "CC": "clang", "CXX": "clang++" } },
    { "name": "debug",   "hidden": true, "inherits": "base", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
    { "name": "release", "hidden": true, "inherits": "base", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" } },
    { "name": "asan", "hidden": true, "inherits": "base", "cacheVariables": { "ENABLE_ASAN": "ON" } },
    { "name": "tsan", "hidden": true, "inherits": "base", "cacheVariables": { "ENABLE_TSAN": "ON" } },
    { "name": "debug-gcc",     "inherits": ["gcc",   "debug"], "displayName": "Debug (GCC)"     },
    { "name": "debug-clang",   "inherits": ["clang", "debug"], "displayName": "Debug (Clang)"   },
    { "name": "release-gcc",   "inherits": ["gcc",   "release"], "displayName": "Release (GCC)"   },
    { "name": "release-clang", "inherits": ["clang", "release"], "displayName": "Release (Clang)" },
    { "name": "asan-gcc",      "inherits": ["debug-gcc",   "asan"], "displayName": "ASan (GCC)"      },
    { "name": "asan-clang",    "inherits": ["debug-clang", "asan"], "displayName": "ASan (Clang)"    },
    { "name": "tsan-gcc",      "inherits": ["debug-gcc",   "tsan"], "displayName": "TSan (GCC)"      },
    { "name": "tsan-clang",    "inherits": ["debug-clang", "tsan"], "displayName": "TSan (Clang)"    }
  ],
  "buildPresets":
  [
    { "name": "debug-gcc",     "configurePreset": "debug-gcc"     },
    { "name": "debug-clang",   "configurePreset": "debug-clang"   },
    { "name": "release-gcc",   "configurePreset": "release-gcc"   },
    { "name": "release-clang", "configurePreset": "release-clang" },
    { "name": "asan-gcc",      "configurePreset": "asan-gcc"      },
    { "name": "asan-clang",    "configurePreset": "asan-clang"    },
    { "name": "tsan-gcc",      "configurePreset": "tsan-gcc"      },
    { "name": "tsan-clang",    "configurePreset": "tsan-clang"    }
  ]
}
